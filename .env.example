DATABASE_URL="postgresql://user:password@localhost:5432/flexvault_dev?schema=public"

# Auth.js
AUTH_SECRET="generate-a-random-secret-with-npx-auth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — leave blank to disable Google sign-in)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Vercel Blob (optional — leave blank to fall back to local-disk uploads in dev.
# Set automatically when a Blob store is connected to the Vercel project.)
BLOB_READ_WRITE_TOKEN=""
